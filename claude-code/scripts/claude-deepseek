#!/bin/bash
# DeepSeek 官方 API — Claude Code（Anthropic 格式）
# 用法: claude-deepseek [模型名] [claude参数...]
#   claude-deepseek                  → 默认 deepseek-v4-pro
#   claude-deepseek deepseek-v4-flash → Flash 快速版
#   claude-deepseek -p "问题"        → 不指定模型，直接传参给 claude
export ANTHROPIC_API_KEY=""
export ANTHROPIC_AUTH_TOKEN="sk-4b266b0d02564bdd8b91bee9e1fb773e"
export ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
export ANTHROPIC_SMALL_FAST_MODEL="deepseek-v4-flash"
export ANTHROPIC_MAX_CONTEXT_TOKENS=1000000
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
export API_TIMEOUT_MS=600000

# 如果第一个参数不是 - 开头，视为模型名；否则用默认模型
if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then
  export ANTHROPIC_MODEL="$1"
  shift
else
  export ANTHROPIC_MODEL="deepseek-v4-pro"
fi

echo "[deepseek] $ANTHROPIC_MODEL (1M context)"
claude "$@"
